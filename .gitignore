# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
build/
dist/

# Models, weights, datasets — never commit these
*.bin
*.safetensors
*.pt
*.pth
*.ckpt
*.gguf
checkpoints/
wandb/
runs/
models/

# Real agent traces — gitignored, may contain customer data
data/traces/*
!data/traces/.gitkeep

# Synthetic dataset — track only canonical splits, not shards or raw dumps.
# To regenerate: `python -m data.generate` then `python -m data.merge`.
data/synthetic/**/raw-*.jsonl
data/synthetic/**/filtered-*.jsonl
data/synthetic/**/*.parquet
# MLX-LM staging dirs — regenerated from canonical splits via prepare_mlx.py
data/synthetic/**/mlx_lora/
data/synthetic/**/mlx_lora_dry/

# Working Parquet builds — regenerable via evals/v0.2/build_parquet.py;
# the canonical published copies live inside the HF dataset, not in this repo.
evals/v0.2/data/

# Eval results — only the canonical `published/` subtree is tracked.
# Everything else under evals/results/ is exploratory and gitignored.
evals/results/*
!evals/results/.gitkeep
!evals/results/published/

# Secrets
.env
.env.local
*.key
*.pem

# Temp briefing / review / workshop docs (ad-hoc, not part of the canonical doc set)
REVIEW_BRIEF.md
REVIEW_*.md
PLAN-v0.*.md

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
.history/
*.swp
*.swo
.DS_Store

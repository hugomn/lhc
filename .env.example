# Ember — local environment variables.
# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# ─── Target models (the model being evaluated) ─────────────────────────

# Moonshot (Kimi K2.6 — currently the strongest open agent base candidate)
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.ai/v1
MOONSHOT_MODEL=kimi-k2.6

# OpenAI (for GPT baselines)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic (for Claude baselines and as the default cross-judge)
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
# Default judge model. Override to claude-sonnet-4-6 to cut judge costs ~3×.
ANTHROPIC_MODEL=claude-opus-4-7

# DeepSeek (for DeepSeek baselines, also usable as a judge)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-pro

# Slow Lit Labs API (Ember itself; defaults to a local mlx_lm.server on :8080)
SLOWLIT_API_KEY=local
SLOWLIT_BASE_URL=http://localhost:8080/v1
SLOWLIT_MODEL=qwen3-8b   # set to ember-v0.1 once trained

# ─── Optional ──────────────────────────────────────────────────────────

# Weights & Biases — for training-run telemetry
WANDB_API_KEY=
